# Copy to .env.local and fill in real values:
#   cp .env.example .env.local

# Convex — `pnpm convex dev` writes NEXT_PUBLIC_CONVEX_URL + CONVEX_DEPLOYMENT
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_DEPLOYMENT=dev:your-project-name

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Same issuer URL as in Clerk (JWT template name must be "convex")
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev
# Optional: only after Clerk Billing + Stripe is set up
# NEXT_PUBLIC_CLERK_BILLING_ENABLED=true

# Vercel Blob — store "lead" (linked project injects this name)
LEAD_READ_WRITE_TOKEN=vercel_blob_rw_...
# Optional fallback if you only use the generic Quickstart name:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Inngest
# Signing key: App → Sync / Developer → or Environment → Keys (starts with signkey-)
# Event key: https://app.inngest.com → top env (e.g. Production) → Manage → Keys → "+ Create Event Key"
#   (Event keys are listed here; paste into INNGEST_EVENT_KEY)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# AssemblyAI — https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
